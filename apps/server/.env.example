# Copy to .env and fill in values

# SQLite path — use /data/latent-space.db on Railway (persistent volume at /data)
DATABASE_URL=./latent-space.db

# Random string, 32+ chars — generate with: openssl rand -hex 32
SESSION_SECRET=change_me_generate_with_openssl_rand_hex_32

# From resend.com dashboard
RESEND_API_KEY=re_xxxx

# The full URL your server is reachable at (Railway gives you one automatically)
MAGIC_LINK_BASE_URL=https://your-app.up.railway.app
CLIENT_URL=https://your-app.up.railway.app

# Railway sets PORT automatically — don't set this manually on Railway
# PORT=3001
